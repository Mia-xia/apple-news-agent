# Apple News Monitoring Agent - Environment Configuration Example
# Copy this file to .env and fill in your actual credentials

# NEWS API KEYS
# Get your NewsAPI key from: https://newsapi.org/
NEWSAPI_KEY=your_newsapi_key_here

# TWITTER/X API (v2)
# Get credentials from: https://developer.twitter.com/
TWITTER_API_KEY=your_twitter_api_key
TWITTER_API_SECRET=your_twitter_api_secret
TWITTER_BEARER_TOKEN=your_bearer_token

# OPENAI API (optional, for AI-powered summarization)
OPENAI_API_KEY=your_openai_key

# EMAIL CONFIGURATION
# Gmail example (enable "Less secure app access" or use App Password)
EMAIL_SENDER=your-email@gmail.com
EMAIL_PASSWORD=your_app_password
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587

# Comma-separated list of recipient emails
EMAIL_RECIPIENTS=recipient1@example.com,recipient2@example.com,recipient3@example.com

# SLACK (optional)
# Create Slack webhook: https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# SCHEDULE SETTINGS
# Time to run daily briefing (24-hour format, UTC)
SCHEDULE_TIME=09:00
TIMEZONE=UTC
